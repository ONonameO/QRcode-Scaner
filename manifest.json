{
  "manifest_version": 3,
  "name": "QRcode Scaner（二维码识别器）",
  "version": "1.0.0",
  "description": "使用草料二维码API解析二维码（需联网），基本能识别通用二维码和市面上大部分APP专属二维码。支持右键菜单识别、网页截图识别、上传本地图片识别和从剪切板识别。",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "clipboardRead",
    "offscreen",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icon32.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png"
    }
  },
  "icons": {
    "32": "icons/icon32.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html", "offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ]
}